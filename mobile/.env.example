# mobile/.env.example
# Copiar a `mobile/.env` (NUNCA commitear) o cargar via direnv/dotenv para desarrollo local.
# En EAS Build estos valores se inyectan desde `eas secret:create` (ver BUILD_INSTRUCTIONS.md).

# Google Maps SDK Android — restringida por package + SHA-1 en GCP.
GOOGLE_MAPS_API_KEY_ANDROID=

# Google OAuth 2.0 — Web Client ID (público, pero centralizado aquí).
GOOGLE_WEB_CLIENT_ID=

# Stripe — publishable key (pk_test_* en dev, pk_live_* solo en production profile).
STRIPE_PUBLISHABLE_KEY=

# Backend API base URL (override del default https://api.cuponiko.com).
API_BASE_URL=https://cuponiko-production.up.railway.app

# EAS Project ID (lo devuelve `eas init`; en CI lo inyecta EAS automáticamente).
EAS_PROJECT_ID=
