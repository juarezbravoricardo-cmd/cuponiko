# ====== Cuponiko API — variables de entorno ======
# Copiar a .env y completar valores reales (nunca commitear .env)

# Server
NODE_ENV=development
PORT=3000
# CORS: lista separada por comas de orígenes permitidos
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:3000

# Database (Supabase Session Pooler)
DATABASE_URL=postgres://postgres:<password>@<host>:5432/postgres

# JWT
JWT_SECRET=replace-with-random-256-bit-hex
JWT_REFRESH_SECRET=replace-with-random-256-bit-hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
INTERNAL_SECRET=replace-with-random-hex

# Bcrypt
BCRYPT_COST=12

# Mocks (solo para tests / dev local)
MOCK_EXTERNAL_SERVICES=false

# Google OAuth 2.0
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# Google Maps (Geocoding)
GOOGLE_MAPS_API_KEY=AIzaXXXXXX

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PREMIUM=price_xxx
STRIPE_SUCCESS_URL=https://app.cuponiko.mx/billing/success
STRIPE_CANCEL_URL=https://app.cuponiko.mx/billing/cancel
# Precio Premium en MXN (solo para cálculo de MRR en ADMIN-08; el cobro real lo hace Stripe)
PREMIUM_PRICE_MXN=399

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_PHONE_NUMBER=+521XXXXXXXXXX

# Supabase Storage
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Rate limits
RATE_LIMIT_GLOBAL_PER_MIN=100
RATE_LIMIT_BUSINESS_REGISTER_PER_DAY=3
